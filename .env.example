# NEXT.JS SERVER & TURSO DB CONNECTION
TURSO_CONNECTION_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# FIREBASE CLIENT CONFIG (Publicly Exposed)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_if_applicable
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_push_key_here

# FIREBASE ADMIN CONFIG (Server-Side Only - Private)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your_admin_sdk_service_account_email
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_lines_here\n-----END PRIVATE KEY-----"

# API & WEBHOOK KEYS (Private)
KAMPUSFILTER_API_KEY=your_webhook_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
